# The GUI stores credentials securely in your OS credential vault — you do NOT
# need this file to use the app. This .env is only a fallback for the headless
# CLI (`uv run main.py --cli`).

IGP_USER=your_igpsport_email
IGP_PASS=your_igpsport_password
INTERVALS_API_KEY=your_intervals_api_key

# Optional overrides (otherwise read from the GUI's saved config.json):
# MAX_ACTIVITIES=5
# STEP_LIST_ACTIVITIES=true
# STEP_GET_DOWNLOAD_URL=true
# STEP_DOWNLOAD_FIT=true
# STEP_UPLOAD_INTERVALS=true
